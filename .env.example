# =========================================================================
# CONFIGURATION FOR OTO-CERDAS AI (ASISTEN OTOMOTIF CERDAS)
# =========================================================================

# --- LLM PROVIDERS CONFIGURATION ---
# Choose your preferred LLM provider. Supported: "openai" or "google"
MODEL_PROVIDER=openai

# If using OpenAI (e.g., gpt-4o-mini, gpt-3.5-turbo)
OPENAI_API_KEY=your_openai_api_key_here

# If using Google Gemini (e.g., gemini-1.5-flash)
GOOGLE_API_KEY=your_google_api_key_here

# --- LANGSMITH TRACING CONFIGURATION (MANDATORY FOR MONITORING) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=asisten-otomotif-cerdas
